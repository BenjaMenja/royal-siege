{
  "type": "minecraft:multi_action",
  "title": {
    "text": "Archer Shop",
    "color": "aqua"
  },
  "body": [
    {
      "type": "minecraft:plain_message",
      "width": 600,
      "contents": [
        {
          "text": "The archer is a long range fighter that excels in projectile based combat.\n\n",
          "color": "aqua"
        },
        {
          "text": "Passive - Hit and Run\n\n",
          "color": "yellow"
        },
        {
          "text": "Landing a hit with your bow and arrow will grant you +10% movement speed for 3s. Consecutive hits refresh the speed and increase the power of the speed by 10%, up to 30%."
        }
      ]
    }
  ],
  "columns": 2,
  "actions": [
    {
      "label": [
        {
          "atlas": "minecraft:items",
          "sprite": "item/sniper_bow"
        },
        {
          "text": " Sniper Bow"
        }
      ],
      "tooltip": {
        "text": "Cost - 700 Siege Bucks\nA very high power bow that slows your movement speed by 65%.\nArrows fired from this bow are not affected by gravity.",
        "color": "gold"
      },
      "action": {
        "type": "minecraft:run_command",
        "command": "trigger textClick set 25"
      }
    },
    {
      "label": [
