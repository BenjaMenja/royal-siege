{
  "type": "minecraft:multi_action",
  "title": {
    "text": "Astronaut Shop",
    "color": "aqua"
  },
  "body": [
    {
      "type": "minecraft:plain_message",
      "width": 600,
      "contents": [
        {
          "text": "The astronaut utilizes their array of tools to assist their teammates in unexpected ways.\n\n",
          "color": "aqua"
        },
        {
          "text": "Passive - Gravity Suit\n\n",
          "color": "yellow"
        },
        {
          "text": "Your space suit alters how gravity affects you.\nYour jump height is increased and you fall slower.\nHolding the sneak button causes you to fall quickly."
        }
      ]
    }
  ],
  "columns": 2,
  "actions": [
