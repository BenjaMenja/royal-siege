      "contents": [
        {
          "type": "text",
          "text": "Strengths\n",
          "bold": true,
          "color": "red"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "red"
        },
        {
          "type": "text",
          "text": "Strong pocketing capabilites can greatly enhance a teammate's fighting power.\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "red"
        },
        {
          "type": "text",
          "text": "Synergizes with debuffing characters and can apply debuffs herself.\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "red"
        },
        {
          "type": "text",
          "text": "Dynamic playstyle allows her to focus on a single teammate or the entire team.\n\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "Weaknesses\n",
          "bold": true,
          "color": "blue"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "blue"
        },
        {
          "type": "text",
          "text": "Low buffing capabilities outside of healing.\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "blue"
        },
        {
          "type": "text",
          "text": "Can be overwhelmed easily without her passive upgrade.\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "blue"
        },
        {
          "type": "text",
          "text": "Relatively weak self combat capabilities.\n",
          "bold": false,
          "color": "white"
        }
