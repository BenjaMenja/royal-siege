    {
      "type": "minecraft:plain_message",
      "width": 512,
      "contents": [
        {
          "type": "text",
          "text": "Strengths\n",
          "bold": true,
          "color": "red"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "red"
        },
        {
          "type": "text",
          "text": "Burst movement helps secure kills and evade dangerous situations.\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "red"
        },
        {
          "type": "text",
          "text": "Shop items allow the ninja to adapt mid-battle.\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "red"
        },
        {
          "type": "text",
          "text": "High attack speed and damage output can burst down low defense targets.\n\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "Weaknesses\n",
          "bold": true,
          "color": "blue"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "blue"
        },
        {
          "type": "text",
          "text": "Very low overall defense can result in quick, sometimes unexpected deaths.\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "blue"
        },
        {
          "type": "text",
          "text": "High execution level can make it difficult to capitalize on situations.\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "blue"
        },
        {
          "type": "text",
          "text": "Difficult to survive in longer fights.\n",
          "bold": false,
          "color": "white"
        }
      ]
    }
