      "contents": [
        {
          "type": "text",
          "text": "Strengths\n",
          "bold": true,
          "color": "red"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "red"
        },
        {
          "type": "text",
          "text": "High damage reduction greatly increases survivability in a variety of scenarios.\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "red"
        },
        {
          "type": "text",
          "text": "Shield protects against projectiles and supports a melee focused playstyle.\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "red"
        },
        {
          "type": "text",
          "text": "Very powerful ultimates can turn the tide of battle with relative ease.\n\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "Weaknesses\n",
          "bold": true,
          "color": "blue"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "blue"
        },
        {
          "type": "text",
          "text": "Low, slow damage output can make it difficult to deal with persistent threats alone.\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "blue"
        },
        {
          "type": "text",
          "text": "Lack of proper ranged damage can make fighting ranged enemies difficult.\n",
          "bold": false,
          "color": "white"
        },
        {
          "type": "text",
          "text": "- ",
          "bold": false,
          "color": "blue"
        },
        {
          "type": "text",
          "text": "Disabled shield can render the guardian rather vulnerable.\n",
          "bold": false,
          "color": "white"
        }
      ]
    }
